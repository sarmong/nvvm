#!/usr/bin/env bash

set -euo pipefail

VERSION="0.0.1"

dir=${XDG_DATA_HOME:-$HOME/.local/share}/nvvm
BIN_DIR=$dir/bin
LIB_DIR=$dir/lib
CACHE_DIR=${XDG_CACHE_HOME:-$HOME/.cache}/nvvm
last_updated_file="$CACHE_DIR/last_updated"

_partial_download=""

cleanup() {
  if [ -n "$_partial_download" ]; then
    rm -f "$_partial_download"
  fi
}

trap cleanup EXIT

usage() {
  echo "Usage: nvvm <command> [options]" >&2
  echo "Commands:" >&2
  echo "  install <version>   Install a specific version of neovim (e.g., 'latest', 'stable', '0.5.0')" >&2
  echo "  use <version>       Use a specific version of neovim (e.g., 'latest', 'stable', '0.5.0')" >&2
  echo "  list [-a|--all]     List available versions of neovim (shows 20 most recent by default)" >&2
  echo "  run <version>       Run a specified version of neovim (e.g., 'latest', 'stable', '0.5.0')" >&2
  echo "  uninstall <version> Remove an installed version of neovim" >&2
  echo "  refresh             Refresh the releases cache" >&2
}

check_deps() {
  local missing=()
  for dep in curl jq sha256sum; do
    command -v "$dep" >/dev/null 2>&1 || missing+=("$dep")
  done
  if [ ${#missing[@]} -gt 0 ]; then
    printf "nvvm: missing required dependencies: %s\n" "${missing[*]}" >&2
    return 1
  fi
}

main() {
  if [ -z "${1-}" ]; then
    usage
    exit 1
  fi

  case "$1" in
    --help | -h | help)
      usage
      exit 0
      ;;
    --version | -v)
      echo "nvvm $VERSION"
      exit 0
      ;;
  esac

  check_deps

  local cmd="$1"
  shift

  [ ! -d "$BIN_DIR" ] && mkdir -p "$BIN_DIR"
  [ ! -d "$LIB_DIR" ] && mkdir -p "$LIB_DIR"
  [ ! -d "$CACHE_DIR" ] && mkdir -p "$CACHE_DIR"

  case "$cmd" in
    install) install "$@" ;;
    uninstall) uninstall "$@" ;;
    use) use "$@" ;;
    list) list "$@" ;;
    run) run "$@" ;;
    refresh) refresh ;;
    *)
      printf "Unknown command: %s\n\n" "$cmd" >&2
      usage
      exit 1
      ;;
  esac
}

## Resolve a version string to a full semver.
## stable/latest: resolved via releases cache to latest non-prerelease semver.
## Full semver (X.Y.Z) and non-numeric aliases (nightly): pass through unchanged.
## Partial semver (X.Y): resolved to latest matching release.
resolve_version() {
  local version="$1"

  # Resolve stable/latest aliases to actual semver
  if [[ "$version" == "stable" || "$version" == "latest" ]]; then
    local resolved
    resolved=$(get_releases | jq -r '
      [.[] | select(
        .prerelease == false and
        .draft == false and
        (.tag_name | test("^v[0-9]+\\.[0-9]+\\.[0-9]+$"))
      )] | first | .tag_name | ltrimstr("v")')
    if [ -z "$resolved" ]; then
      printf "nvvm: could not resolve '%s' to a version\n" "$version" >&2
      return 1
    fi
    echo "$resolved"
    return
  fi

  # Full semver and other non-numeric aliases (nightly) pass through unchanged
  if [[ ! "$version" =~ ^[0-9] ]] || [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "$version"
    return
  fi

  # Partial semver: resolve to latest matching release
  local resolved
  resolved=$(get_releases | jq -r --arg prefix "v${version}." \
    'map(select(.tag_name | startswith($prefix))) | first | .tag_name // empty' |
    sed 's/^v//')
  if [ -z "$resolved" ]; then
    printf "nvvm: no release found matching '%s'\n" "$version" >&2
    return 1
  fi
  echo "$resolved"
}

## Resolve a version string to a locally installed full semver.
## stable/latest: resolved via their $BIN_DIR/nvim-<alias> symlink — no network.
## Full semver: passes through unchanged.
## Partial semver: scans $LIB_DIR and picks highest matching installed version.
resolve_installed_version() {
  local version="$1"

  ## Resolve stable/latest via alias symlinks in BIN_DIR
  if [[ "$version" == "stable" || "$version" == "latest" ]]; then
    local alias_file="$BIN_DIR/nvim-$version"
    if [ ! -L "$alias_file" ]; then
      printf "nvvm: '%s' has not been installed\n" "$version" >&2
      return 1
    fi
    local target
    target=$(readlink -f "$alias_file")
    # Path is: .../lib/<version>/bin/nvim — extract <version>
    basename "$(dirname "$(dirname "$target")")"
    return
  fi

  # Full semver and non-numeric aliases (nightly) pass through unchanged
  if [[ ! "$version" =~ ^[0-9] ]] || [[ "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    echo "$version"
    return
  fi

  # Partial semver: find highest installed matching version
  local resolved
  local matches=()
  for d in "$LIB_DIR/${version}".*; do
    [[ -d "$d" ]] && matches+=("$(basename "$d")")
  done
  resolved=$(printf '%s\n' "${matches[@]}" | sort -V | tail -1)
  if [ -z "$resolved" ]; then
    printf "nvvm: no installed version matches '%s'\n" "$version" >&2
    return 1
  fi
  echo "$resolved"
}

## Create $BIN_DIR/nvim-stable and $BIN_DIR/nvim-latest symlinks for a given version.
_create_alias_symlinks() {
  local version="$1"
  local version_dir="$LIB_DIR/$version"
  ln -sf "nvim-$version" "$BIN_DIR/nvim-stable"
  ln -sf "nvim-$version" "$BIN_DIR/nvim-latest"
}

## Create alias symlinks only if the given version is the current stable release.
## Uses cached releases — no extra network call if get_releases cache is warm.
_create_alias_symlinks_if_needed() {
  local version="$1"
  local stable_version
  stable_version=$(get_releases | jq -r '
    [.[] | select(
      .prerelease == false and
      .draft == false and
      (.tag_name | test("^v[0-9]+\\.[0-9]+\\.[0-9]+$"))
    )] | first | .tag_name | ltrimstr("v")')
  if [[ "$version" == "$stable_version" ]]; then
    _create_alias_symlinks "$version"
  fi
}

_pick() {
  fzf --height=40% --reverse --prompt="$1 > "
}

_require_fzf() {
  command -v fzf >/dev/null 2>&1 || {
    printf "Usage: nvvm %s\n" "$1" >&2
    return 1
  }
}

## Prints installed version names sorted oldest-to-newest, one per line.
_installed_versions() {
  local d
  for d in "$LIB_DIR"/*/; do
    [ -d "$d" ] || continue
    [ -f "$d/bin/nvim" ] || continue
    basename "$d"
  done | sort --reverse
}

_install_xdg_assets() {
  local version="$1"
  local nvim_share_dir="$LIB_DIR/$version/share"
  local xdg_data="${XDG_DATA_HOME:-$HOME/.local/share}"

  [ -f "$nvim_share_dir/applications/nvim.desktop" ] &&
    command install -Dm644 "$nvim_share_dir/applications/nvim.desktop" "$xdg_data/applications/nvim.desktop"

  if [ -d "$nvim_share_dir/icons/hicolor" ]; then
    while IFS= read -r -d '' src; do
      local rel="${src#"$nvim_share_dir/icons/hicolor/"}"
      command install -Dm644 "$src" "$xdg_data/icons/hicolor/$rel"
    done < <(find "$nvim_share_dir/icons/hicolor" -type f -print0)
  fi

  [ -f "$nvim_share_dir/man/man1/nvim.1" ] &&
    command install -Dm644 "$nvim_share_dir/man/man1/nvim.1" "$xdg_data/man/man1/nvim.1"

  command -v update-desktop-database >/dev/null 2>&1 &&
    update-desktop-database "$xdg_data/applications"
  command -v gtk-update-icon-cache >/dev/null 2>&1 &&
    gtk-update-icon-cache -f -t "$xdg_data/icons/hicolor" >/dev/null 2>&1

  return 0
}

_remove_xdg_assets() {
  local xdg_data="${XDG_DATA_HOME:-$HOME/.local/share}"

  rm -f "$xdg_data/applications/nvim.desktop"
  rm -f "$xdg_data/man/man1/nvim.1"
  find "$xdg_data/icons/hicolor" -name "nvim.*" -type f -delete 2>/dev/null || true

  command -v update-desktop-database >/dev/null 2>&1 &&
    update-desktop-database "$xdg_data/applications"
  command -v gtk-update-icon-cache >/dev/null 2>&1 &&
    gtk-update-icon-cache -f -t "$xdg_data/icons/hicolor" >/dev/null

  return 0
}

get_file_url() {
  local version="$1"
  get_release_asset "$version" | jq -r '.browser_download_url'
}

list() {
  local all=0
  for arg in "$@"; do
    case "$arg" in
      --all | -a) all=1 ;;
    esac
  done

  local tags
  tags=$(get_releases | jq -r '[.[].tag_name] | .[]')
  [ "$all" -eq 0 ] && tags=$(echo "$tags" | head -20)

  echo "$tags" | while read -r tag; do
    local version="${tag#v}"
    if [ "$BIN_DIR/nvim" -ef "$LIB_DIR/$version/bin/nvim" ]; then
      echo "* $version (current)"
    elif [ -f "$LIB_DIR/$version/bin/nvim" ]; then
      echo "* $version"
    else
      echo "  $version"
    fi
  done
}

use() {
  if [ -z "${1-}" ]; then
    _require_fzf "use <version>"

    local active=""
    [ -L "$BIN_DIR/nvim" ] && active=$(readlink -f "$BIN_DIR/nvim")

    local list
    list=$(_installed_versions | while IFS= read -r v; do
      [ "$(readlink -f "$LIB_DIR/$v/bin/nvim")" = "$active" ] || echo "$v"
    done)

    if [ -z "$list" ]; then
      echo "nvvm: No non-active installed versions available" >&2
      return 1
    fi

    local version
    version=$(echo "$list" | _pick "use")
    [ -z "$version" ] && return 1

    use "$version"
    return
  fi

  local version="$1"
  local version_number
  version_number="$(resolve_version "$version")"
  local version_file="$BIN_DIR/nvim-$version_number"
  local version_dir="$LIB_DIR/$version_number"

  if [ ! -f "$version_dir/bin/nvim" ]; then
    rm -f "$version_file"
    install "$version_number"
  fi

  # Recreate version symlink if stale or missing
  if [ ! -f "$version_file" ]; then
    ln -sf "$version_dir/bin/nvim" "$version_file"
  fi

  if [[ "$version" == "stable" || "$version" == "latest" ]]; then
    _create_alias_symlinks "$version_number"
    ln -sf "nvim-$version" "$BIN_DIR/nvim"
  else
    ln -sf "$version_dir/bin/nvim" "$BIN_DIR/nvim"
  fi

  _install_xdg_assets "$version_number"
  echo "Now using neovim $version_number"
}

run() {
  if [ -z "${1-}" ]; then
    _require_fzf "run <version> [args...]"

    local active=""
    [ -L "$BIN_DIR/nvim" ] && active=$(readlink -f "$BIN_DIR/nvim")

    local list
    list=$(_installed_versions | while IFS= read -r v; do
      if [ -n "$active" ] && [ "$(readlink -f "$LIB_DIR/$v/bin/nvim")" = "$active" ]; then
        echo "$v (current)"
      else
        echo "$v"
      fi
    done)

    if [ -z "$list" ]; then
      echo "nvvm: No installed versions available" >&2
      return 1
    fi

    local selected
    selected=$(echo "$list" | _pick "run")
    [ -z "$selected" ] && return 1

    local version="${selected% \(current\)}"
    run "$version"
    return
  fi

  local version="$1"
  local version_file="$BIN_DIR/nvim-$version"

  ## Direct lookup: handles exact versions and aliases (nvim-stable, nvim-0.10.4, etc.)
  if [ ! -f "$version_file" ]; then
    ## Fallback to resolve for partial semvers (e.g. "0.10")
    local version
    version="$(resolve_installed_version "$version")"
    version_file="$BIN_DIR/nvim-$version"
    if [ ! -f "$version_file" ]; then
      printf "ERROR: Version %s not installed. Install first\n" "$version" >&2
      return 1
    fi
  fi

  shift
  "$version_file" "$@"
}

install() {
  if [ -z "${1-}" ]; then
    _require_fzf "install <version>"

    local list
    list=$(get_releases | jq -r '[.[].tag_name | ltrimstr("v")] | .[]' | while IFS= read -r v; do
      [ -f "$LIB_DIR/$v/bin/nvim" ] && [ "$v" != "nightly" ] || echo "$v"
    done)

    if [ -z "$list" ]; then
      echo "nvvm: No uninstalled versions available" >&2
      return 1
    fi

    local version
    version=$(echo "$list" | _pick "install") || return 1
    [ -z "$version" ] && return 1

    install "$version"
    return
  fi

  local version
  version="$(resolve_version "$1")"
  local version_file="$BIN_DIR/nvim-$version"

  if [ -f "$version_file" ] && [ "$version" != "nightly" ]; then
    echo "Version $version already installed"
    return 0
  fi

  echo "Installing $version..."

  local remote_file_url
  remote_file_url="$(get_file_url "$version")"

  if [ -z "$remote_file_url" ] || [ "$remote_file_url" = "null" ]; then
    echo "ERROR: Could not find download URL for version $version" >&2
    return 1
  fi

  local remote_filename
  remote_filename="$(basename "$remote_file_url")"
  local default_installed_filepath="$LIB_DIR/$remote_filename" #TODO: use cache dir

  _partial_download="$default_installed_filepath"
  curl -L --progress-bar -o "$default_installed_filepath" "$remote_file_url"

  if ! check_checksum "$version" "$default_installed_filepath"; then
    echo "ERROR: Checksum verification failed" >&2
    return 1
  else
    echo "Checksum verification passed"
  fi

  local version_dir="$LIB_DIR/$version"
  [ ! -d "$version_dir" ] && mkdir -p "$version_dir"

  tar -zxvf "$default_installed_filepath" --directory="$version_dir" --strip-components=1 >/dev/null

  rm "$default_installed_filepath"
  _partial_download=""

  ln -sf "$version_dir/bin/nvim" "$version_file"

  _create_alias_symlinks_if_needed "$version"

  echo "Installed neovim $version at $version_file"

  if [ ! -L "$BIN_DIR/nvim" ]; then
    use "$version"
  fi
}

uninstall() {
  local force=0
  local args=()
  for arg in "$@"; do
    case "$arg" in
      --force | -f) force=1 ;;
      *) args+=("$arg") ;;
    esac
  done

  if [ ${#args[@]} -eq 0 ]; then
    echo "Usage: nvvm uninstall [--force|-f] <version>" >&2
    return 1
  fi

  local version
  version="$(resolve_installed_version "${args[0]}")"
  local version_dir="$LIB_DIR/$version"
  local version_file="$BIN_DIR/nvim-$version"

  if [ ! -d "$version_dir" ]; then
    printf "nvvm: version %s is not installed\n" "$version" >&2
    return 1
  fi

  local active_link="$BIN_DIR/nvim"
  local is_active=0
  if [ -L "$active_link" ] && [ "$(readlink -f "$active_link")" = "$(readlink -f "$version_dir/bin/nvim")" ]; then
    is_active=1
  fi

  if [ "$is_active" -eq 1 ] && [ "$force" -eq 0 ]; then
    printf "nvvm: version %s is currently active. Use --force (-f) to uninstall anyway.\n" "$version" >&2
    return 1
  fi

  ## Find alias symlinks pointing to this version before deleting the dir
  local aliases_to_remove=()
  for alias in stable latest; do
    local alias_file="$BIN_DIR/nvim-$alias"
    if [ -L "$alias_file" ] &&
      [ "$(readlink -f "$alias_file")" = "$(readlink -f "$version_dir/bin/nvim")" ]; then
      aliases_to_remove+=("$alias")
    fi
  done

  rm -f "$version_file"
  rm -rf "$version_dir"

  ## Remove alias symlinks that pointed to the deleted version
  for alias in "${aliases_to_remove[@]}"; do
    rm -f "$BIN_DIR/nvim-$alias"
  done

  echo "Uninstalled neovim $version"

  if [ "$is_active" -eq 1 ]; then
    rm -f "$active_link"
    _remove_xdg_assets
    echo "Warning: no version is currently active. Run 'nvvm use <version>' to set one."
  fi
}

refresh() {
  rm -f "$last_updated_file"

  echo "Fetching latest releases..."
  get_releases >/dev/null

  if [ -f "$last_updated_file" ]; then
    echo "Done."
  else
    echo "Refresh failed, using stale cache." >&2
  fi
}

get_releases() {
  local releases_api_url="https://api.github.com/repos/neovim/neovim/releases?per_page=100"
  local cache_file="$CACHE_DIR/releases.json"

  if [ -f "$cache_file" ] && [ -f "$last_updated_file" ]; then
    local last_updated now
    last_updated=$(cat "$last_updated_file")
    now=$(date +%s)

    # Pull from cache if last updated less than an hour ago
    if ((now - last_updated < 3600)); then
      cat "$cache_file"
      return
    fi
  fi

  local tmp_file
  tmp_file=$(mktemp)

  if ! curl -s --fail "$releases_api_url" --output "$tmp_file"; then
    rm -f "$tmp_file"
    echo "ERROR: Failed to fetch releases from GitHub API (HTTP error)" >&2
    if [ -f "$cache_file" ]; then
      echo "WARNING: Using stale cache" >&2
      cat "$cache_file"
      return
    fi
    return 1
  fi

  if ! jq -e 'type == "array" and length > 0' "$tmp_file" >/dev/null 2>&1; then
    rm -f "$tmp_file"
    echo "ERROR: GitHub API returned an unexpected response" >&2
    if [ -f "$cache_file" ]; then
      echo "WARNING: Using stale cache" >&2
      cat "$cache_file"
      return
    fi
    return 1
  fi

  mv "$tmp_file" "$cache_file"
  date +%s >"$last_updated_file"
  cat "$cache_file"
}

get_release() {
  local version="$1"
  ## Internally versions are stored without 'v', but GitHub tag names use 'v' for semver
  local tag_name="$version"
  if [[ "$version" =~ ^[0-9] ]]; then
    tag_name="v$version"
  fi

  local result
  result=$(get_releases | jq --arg tag "$tag_name" '.[] | select(.tag_name == $tag)')

  if [ -z "$result" ]; then
    ## Not in cached releases (may be older than per_page limit); try direct API lookup
    local fetched
    fetched=$(curl -s --fail "https://api.github.com/repos/neovim/neovim/releases/tags/$tag_name" 2>/dev/null) || true
    if [ -n "$fetched" ] && echo "$fetched" | jq -e '.tag_name' >/dev/null 2>&1; then
      result="$fetched"
    fi
  fi

  echo "$result"
}

get_release_asset() {
  local version="$1"
  get_release "$version" | jq '.assets[] | select(.name == "nvim-linux-x86_64.tar.gz" or .name == "nvim-linux64.tar.gz")'
}

check_checksum_from_digest() {
  local version="$1"
  local filepath="$2"
  local sha256sum
  sha256sum=$(get_release_asset "$version" | jq -r '.digest')

  if [ -z "$sha256sum" ] || [ "$sha256sum" = "null" ]; then
    return 1
  fi

  echo "${sha256sum:7}  $filepath" | sha256sum --check --strict --status -
}

check_checksum_from_file() {
  local version="$1"
  local filepath="$2"
  local shasum_url
  shasum_url=$(get_release "$version" | jq -r --arg filename "$(basename "$filepath")" '.assets[] | select(.name == $filename + ".sha256sum") | .browser_download_url')

  if [ -z "$shasum_url" ] || [ "$shasum_url" = "null" ]; then
    return 1
  fi

  local local_shasum_file="$LIB_DIR/$(basename "$shasum_url")"

  curl -L --progress-bar -o "$local_shasum_file" "$shasum_url"

  if ! (cd "$(dirname "$filepath")" && sha256sum --check --strict --status "$local_shasum_file"); then
    rm "$local_shasum_file"
    return 1
  fi

  rm "$local_shasum_file"
}

check_checksum_from_description() {
  local version="$1"
  local filepath="$2"
  local filename
  filename="$(basename "$filepath")"

  echo "Getting checksum from description..."

  local remote_checksum
  remote_checksum=$(get_release "$version" | jq '.body' | sed 's/\\n/\n/g' | grep -E "\w{64}\s+$filename" | grep -v 'zsync' | awk '{print $1}')

  echo "$remote_checksum  $filepath" | sha256sum --check --strict --status -
}

check_checksum() {
  local version="$1"
  local default_installed_filepath="$2"

  if ! check_checksum_from_digest "$version" "$default_installed_filepath"; then
    if ! check_checksum_from_file "$version" "$default_installed_filepath"; then
      check_checksum_from_description "$version" "$default_installed_filepath"
    fi
  fi
}

main "$@"
