#!/usr/bin/env bash

set -euo pipefail

VERSION="0.0.1"

dir=${XDG_DATA_HOME:-$HOME/.local/share}/nvvm
BIN_DIR=$dir/bin
LIB_DIR=$dir/lib
CACHE_DIR=${XDG_CACHE_HOME:-$HOME/.cache}/nvvm
last_updated_file="$CACHE_DIR/last_updated"

_partial_download=""

cleanup() {
  if [ -n "$_partial_download" ]; then
    rm -f "$_partial_download"
  fi
}

trap cleanup EXIT

usage() {
  echo "Usage: nvvm <command> [options]" >&2
  echo "Commands:" >&2
  echo "  install <version>   Install a specific version of neovim (e.g., 'latest', 'stable', '0.5.0')" >&2
  echo "  use <version>       Use a specific version of neovim (e.g., 'latest', 'stable', '0.5.0')" >&2
  echo "  list                List available versions of neovim" >&2
  echo "  run <version>       Run a specified version of neovim (e.g., 'latest', 'stable', '0.5.0')" >&2
  echo "  refresh             Refresh the releases cache" >&2
}

check_deps() {
  local missing=()
  for dep in curl jq sha256sum; do
    command -v "$dep" >/dev/null 2>&1 || missing+=("$dep")
  done
  if [ ${#missing[@]} -gt 0 ]; then
    printf "nvvm: missing required dependencies: %s\n" "${missing[*]}" >&2
    exit 1
  fi
}

main() {
  if [ -z "${1-}" ]; then
    usage
    exit 1
  fi

  case "$1" in
    --help | -h | help)
      usage
      exit 0
      ;;
    --version | -v)
      echo "nvvm $VERSION"
      exit 0
      ;;
  esac

  check_deps

  local cmd="$1"
  shift

  [ ! -d "$BIN_DIR" ] && mkdir -p "$BIN_DIR"
  [ ! -d "$LIB_DIR" ] && mkdir -p "$LIB_DIR"
  [ ! -d "$CACHE_DIR" ] && mkdir -p "$CACHE_DIR"

  case "$cmd" in
    install) install "$@" ;;
    use) use "$@" ;;
    list) list "$@" ;;
    run) run "$@" ;;
    refresh) refresh ;;
    *)
      printf "Unknown command: %s\n\n" "$cmd" >&2
      usage
      exit 1
      ;;
  esac
}

get_file_url() {
  local version="$1"
  get_release_asset "$version" | jq -r '.browser_download_url'
}

list() {
  get_releases | jq -r '[.[].tag_name] | reverse | .[]' | while read -r version; do
    if [ "$BIN_DIR/nvim" -ef "$LIB_DIR/$version/bin/nvim" ]; then
      echo "* $version (current)"
    elif [ -f "$LIB_DIR/$version/bin/nvim" ]; then
      echo "* $version"
    else
      echo "  $version"
    fi
  done
}

use() {
  if [ -z "${1-}" ]; then
    echo "Usage: nvvm use <version>" >&2
    exit 1
  fi
  local version="$1"
  local version_file="$BIN_DIR/nvim-$version"
  local version_dir="$LIB_DIR/$version"

  if [ ! -f "$version_dir/bin/nvim" ]; then
    rm -f "$version_file"
    install "$version"
  fi

  # Recreate version symlink if stale or missing
  if [ ! -f "$version_file" ]; then
    ln -sf "$version_dir/bin/nvim" "$version_file"
  fi

  ln -sf "$version_dir/bin/nvim" "$BIN_DIR/nvim"

  echo "Now using neovim $version"
}

run() {
  if [ -z "${1-}" ]; then
    echo "Usage: nvvm run <version> [args...]" >&2
    exit 1
  fi
  local version="$1"
  local version_file="$BIN_DIR/nvim-$version"

  if [ ! -f "$version_file" ]; then
    echo "ERROR: Version $version not installed. Install first" >&2
    exit 1
  fi

  shift
  "$version_file" "$@"
}

install() {
  if [ -z "${1-}" ]; then
    echo "Usage: nvvm install <version>" >&2
    exit 1
  fi
  local version="$1"
  local version_number="$version"
  local version_file="$BIN_DIR/nvim-$version_number"

  if [ -f "$version_file" ] && [ "$version" != "nightly" ]; then
    echo "Version $version_number already installed"
    exit 0
  fi

  echo "Installing $version_number..."

  local remote_file_url
  remote_file_url="$(get_file_url "$version_number")"

  if [ -z "$remote_file_url" ] || [ "$remote_file_url" = "null" ]; then
    echo "ERROR: Could not find download URL for version $version_number" >&2
    exit 1
  fi

  local remote_filename
  remote_filename="$(basename "$remote_file_url")"
  local default_installed_filepath="$LIB_DIR/$remote_filename" #TODO: use cache dir

  _partial_download="$default_installed_filepath"
  curl -L --progress-bar -o "$default_installed_filepath" "$remote_file_url"

  if ! check_checksum "$version" "$default_installed_filepath"; then
    echo "ERROR: Checksum verification failed" >&2
    exit 1
  else
    echo "Checksum verification passed"
  fi

  local version_dir="$LIB_DIR/$version_number"
  [ ! -d "$version_dir" ] && mkdir -p "$version_dir"

  tar -zxvf "$default_installed_filepath" --directory="$version_dir" --strip-components=1 >/dev/null

  rm "$default_installed_filepath"
  _partial_download=""

  ln -sf "$version_dir/bin/nvim" "$version_file"

  echo "Installed neovim $version_number at $version_file"

  if [ ! -L "$BIN_DIR/nvim" ]; then
    use "$version"
  fi
}

refresh() {
  rm -f "$last_updated_file"

  echo "Fetching latest releases..."
  get_releases >/dev/null

  if [ -f "$last_updated_file" ]; then
    echo "Done."
  else
    echo "Refresh failed, using stale cache." >&2
  fi
}

get_releases() {
  local releases_api_url="https://api.github.com/repos/neovim/neovim/releases"
  local cache_file="$CACHE_DIR/releases.json"

  if [ -f "$cache_file" ] && [ -f "$last_updated_file" ]; then
    local last_updated now
    last_updated=$(cat "$last_updated_file")
    now=$(date +%s)

    # Pull from cache if last updated less than an hour ago
    if ((now - last_updated < 3600)); then
      cat "$cache_file"
      return
    fi
  fi

  local tmp_file
  tmp_file=$(mktemp)

  if ! curl -s --fail "$releases_api_url" --output "$tmp_file"; then
    rm -f "$tmp_file"
    echo "ERROR: Failed to fetch releases from GitHub API (HTTP error)" >&2
    if [ -f "$cache_file" ]; then
      echo "WARNING: Using stale cache" >&2
      cat "$cache_file"
      return
    fi
    exit 1
  fi

  if ! jq -e 'type == "array" and length > 0' "$tmp_file" >/dev/null 2>&1; then
    rm -f "$tmp_file"
    echo "ERROR: GitHub API returned an unexpected response" >&2
    if [ -f "$cache_file" ]; then
      echo "WARNING: Using stale cache" >&2
      cat "$cache_file"
      return
    fi
    exit 1
  fi

  mv "$tmp_file" "$cache_file"
  date +%s >"$last_updated_file"
  cat "$cache_file"
}

get_release() {
  local version="$1"
  get_releases | jq --arg version "$version" '.[] | select(.tag_name == $version)'
}

get_release_asset() {
  local version="$1"
  get_release "$version" | jq '.assets[] | select(.name == "nvim-linux-x86_64.tar.gz" or .name == "nvim-linux64.tar.gz")'
}

check_checksum_from_digest() {
  local version="$1"
  local filepath="$2"
  local sha256sum
  sha256sum=$(get_release_asset "$version" | jq -r '.digest')

  if [ -z "$sha256sum" ] || [ "$sha256sum" = "null" ]; then
    return 1
  fi

  echo "${sha256sum:7}  $filepath" | sha256sum --check --strict --status -
}

check_checksum_from_file() {
  local version="$1"
  local filepath="$2"
  local shasum_url
  shasum_url=$(get_release "$version" | jq -r --arg filename "$(basename "$filepath")" '.assets[] | select(.name == $filename + ".sha256sum") | .browser_download_url')

  if [ -z "$shasum_url" ] || [ "$shasum_url" = "null" ]; then
    return 1
  fi

  local local_shasum_file="$LIB_DIR/$(basename "$shasum_url")"

  curl -L --progress-bar -o "$local_shasum_file" "$shasum_url"

  if ! (cd "$(dirname "$filepath")" && sha256sum --check --strict --status "$local_shasum_file"); then
    rm "$local_shasum_file"
    return 1
  fi

  rm "$local_shasum_file"
}

check_checksum_from_description() {
  local version="$1"
  local filepath="$2"
  local filename
  filename="$(basename "$filepath")"

  echo "Getting checksum from description..."

  local remote_checksum
  remote_checksum=$(get_release "$version" | jq '.body' | sed 's/\\n/\n/g' | grep -E "\w{64}\s+$filename" | grep -v 'zsync' | awk '{print $1}')

  echo "$remote_checksum  $filepath" | sha256sum --check --strict --status -
}

check_checksum() {
  local version="$1"
  local default_installed_filepath="$2"

  if ! check_checksum_from_digest "$version" "$default_installed_filepath"; then
    if ! check_checksum_from_file "$version" "$default_installed_filepath"; then
      check_checksum_from_description "$version" "$default_installed_filepath"
    fi
  fi
}

main "$@"
